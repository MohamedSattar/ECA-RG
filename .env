# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]
 
# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"
 
# API Base URL - Production Power Pages Portal
VITE_PUBLIC_API_BASE_URL=https://researchgrants-dev.powerappsportals.com
 
# Server-side Azure AD client credentials (used by server proxy to call Dataverse)
# Set these to enable server-side client-credentials token acquisition.
# WARNING: keep client secret out of source control. Set this locally or in CI secrets.
AZURE_TENANT_ID=9bfb065d-cde3-4be3-8515-0b1c8fe6fc29
AZURE_CLIENT_ID=02b145a5-cc87-408e-8333-71b77ce1d8c2
# WARNING: keep client secret out of source control. Set this locally or in CI secrets.
AZURE_CLIENT_SECRET=yGu8Q~Ks0XIGCABfHaeJtfMnSlI8yY_2ejRgMczc
DATAVERSE_RESOURCE=https://ecacrmdev.crm15.dynamics.com/.default
 
# If true, the server proxy will forward the client's Authorization header
# instead of using the server-side client credentials token.
FORWARD_CLIENT_AUTH=true
 
# B2C Client Credentials (for client-side token fallback)
# SECURITY WARNING: Client secrets should NEVER be in source control.
# These are used by the client fallback mechanism only—set these locally or via env vars.
# DO NOT commit these values to git.
VITE_B2C_CLIENT_ID=1dc49cf1-aa12-4bfb-bf9e-60ff6df8475e
VITE_B2C_TOKEN_URL=https://login.microsoftonline.com/9bfb065d-cde3-4be3-8515-0b1c8fe6fc29/oauth2/token
VITE_B2C_SCOPES=openid offline_access
# VITE_B2C_CLIENT_SECRET should be set as an environment variable, NOT in .env
# Example: set VITE_B2C_CLIENT_SECRET=<secret> before running dev server
 
# Session token signing secret — used by the server proxy to issue and verify
# short-lived (8h) HMAC-signed session tokens that carry the user's contactId.
# REQUIRED: generate a cryptographically random string of at least 32 characters.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: keep this out of source control. Set locally or in CI/CD secrets.
SESSION_SECRET=REPLACE_WITH_A_RANDOM_32_CHAR_SECRET

# DEVELOPMENT ONLY: Static fallback token for local testing (expires Feb 10, 2026)
# This allows development/testing when client credentials flow is unavailable
# NEVER use this token in production—it has a short lifetime and is committed to git
